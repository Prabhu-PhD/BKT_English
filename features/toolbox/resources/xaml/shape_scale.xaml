<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:fr="clr-namespace:Fluent;assembly=Fluent"
    ResizeMode="NoResize" SizeToContent="WidthAndHeight" WindowStartupLocation="CenterScreen"
    Title="Scale shapes"
    ShowInTaskbar="False" MinWidth="300">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Fluent;Component/Themes/Generic.xaml" />
           </ResourceDictionary.MergedDictionaries>
       </ResourceDictionary>
   </Window.Resources>

    <StackPanel x:Name="DataPanel" Orientation="Vertical" Margin="5">
        
        <Grid Margin="5" HorizontalAlignment="Center">
          <Grid.RowDefinitions>
              <RowDefinition />
              <RowDefinition />
              <RowDefinition />
              <RowDefinition />
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
              <ColumnDefinition />
              <ColumnDefinition />
              <ColumnDefinition Width="30" />
              <ColumnDefinition />
              <ColumnDefinition />
          </Grid.ColumnDefinitions>

          <Label Grid.Column="0" Grid.Row="0" Content="Target size:" FontWeight="Bold" />

          <RadioButton VerticalContentAlignment="Center" Grid.Column="0" Grid.Row="1" GroupName="scaletarget" Content="Percent" IsChecked="{Binding scale_percent, Mode=TwoWay}" Margin="5" />
          <RadioButton VerticalContentAlignment="Center" Grid.Column="0" Grid.Row="2" GroupName="scaletarget" Content="Width" IsChecked="{Binding scale_width, Mode=TwoWay}" Margin="5" />
          <RadioButton VerticalContentAlignment="Center" Grid.Column="0" Grid.Row="3" GroupName="scaletarget" Content="Height" IsChecked="{Binding scale_height, Mode=TwoWay}" Margin="5" />
          
          <fr:Spinner Grid.Column="1" Grid.Row="1" InputWidth="90" Value="{Binding target_percent, Mode=TwoWay}" Format="0.0 '%'" Increment="5" Minimum="0" SelectAllTextOnFocus="True"/>
          <fr:Spinner Grid.Column="1" Grid.Row="2" InputWidth="90" Value="{Binding target_width, Mode=TwoWay}" Format="0.00 cm" Increment="0.2" Minimum="0" SelectAllTextOnFocus="True"/>
          <fr:Spinner Grid.Column="1" Grid.Row="3" InputWidth="90" Value="{Binding target_height, Mode=TwoWay}" Format="0.00 cm" Increment="0.2" Minimum="0" SelectAllTextOnFocus="True"/>

          <Label Grid.Column="3" Grid.Row="0" Content="Scaling:" FontWeight="Bold" />

          <CheckBox Grid.Column="3" Grid.Row="1" Content="Size" IsChecked="{Binding settings_size, Mode=TwoWay}" Margin="5" />
          <CheckBox Grid.Column="3" Grid.Row="2" Content="Line/border" IsChecked="{Binding settings_line, Mode=TwoWay}" Margin="5" />
          <CheckBox Grid.Column="3" Grid.Row="3" Content="Shadow" IsChecked="{Binding settings_shadow, Mode=TwoWay}" Margin="5" />
          <CheckBox Grid.Column="4" Grid.Row="1" Content="Font size" IsChecked="{Binding settings_font, Mode=TwoWay}" Margin="5" />
          <CheckBox Grid.Column="4" Grid.Row="2" Content="Text-field inner margin" IsChecked="{Binding settings_margin, Mode=TwoWay}" Margin="5" />
          <CheckBox Grid.Column="4" Grid.Row="3" Content="Paragraph format" IsChecked="{Binding settings_indent, Mode=TwoWay}" Margin="5" />

        </Grid>
        
        <Grid Margin="0">
          <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel Orientation="Horizontal" Grid.Column="0">
              <Button Margin="5" MinWidth="80" Padding="5,4" Content="Reset" Click="reset"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Grid.Column="1">
              <Button Margin="5" MinWidth="80" Padding="5,4" Content="Scale" IsDefault="True" Click="scale"/>
              <Button Margin="5" MinWidth="80" Padding="5,4" Content="Cancel" IsCancel="True"  Click="cancel"/>
          </StackPanel>
        </Grid>
    </StackPanel>
</Window>