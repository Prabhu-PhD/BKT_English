<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    ResizeMode="NoResize" SizeToContent="WidthAndHeight" WindowStartupLocation="CenterScreen"
    Title="Clean up slide deck"
    ShowInTaskbar="False" MinWidth="300">

    <Window.Resources>
        <Style x:Key="selectAllBtn" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Static ToolBar.ButtonStyleKey}}">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="Content" Value="&#xE73A;" />
        </Style>
        <Style x:Key="selectNoneBtn" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Static ToolBar.ButtonStyleKey}}">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="Content" Value="&#xE739;" />
        </Style>
   </Window.Resources>

    <StackPanel x:Name="DataPanel" Orientation="Vertical" Margin="5">

        <!-- <Label Content="Select functions:" FontWeight="Bold" FontSize="14"/> -->
        
        <Grid Margin="5" HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Row="0" Grid.Column="0" Margin="5">
                <GroupBox.Header>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Contents" />
                        <Button Style="{StaticResource selectAllBtn}" Tag="contents_all" Click="select_all" />
                        <Button Style="{StaticResource selectNoneBtn}" Tag="contents_all" Click="select_none" />
                    </StackPanel>
                </GroupBox.Header>
                <StackPanel Orientation="Vertical" Margin="5">
                    <CheckBox Content="Remove hidden slides" ToolTip="Delete all hidden slides in the entire slide deck." IsChecked="{Binding cl_remove_hidden_slides, Mode=TwoWay}" Margin="5,2" />
                    <CheckBox Content="Remove notes" ToolTip="Delete all notes in the entire slide deck." IsChecked="{Binding cl_remove_slide_notes, Mode=TwoWay}" Margin="5,2" />
                    <CheckBox Content="Remove comments" ToolTip="Delete all comments in the entire slide deck." IsChecked="{Binding cl_remove_slide_comments, Mode=TwoWay}" Margin="5,2" />
                    <CheckBox Content="Remove author" ToolTip="Remove author from the document properties." IsChecked="{Binding cl_remove_author, Mode=TwoWay}" Margin="5,2" />
                    <CheckBox Content="Remove external links" ToolTip="Removes the link of linked objects (e.g. images and OLE objects)." IsChecked="{Binding cl_break_links, Mode=TwoWay}" Margin="5,2" />
                </StackPanel>
            </GroupBox>

            <GroupBox Grid.Row="1" Grid.Column="0" Margin="5">
                <GroupBox.Header>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Animations" />
                        <Button Style="{StaticResource selectAllBtn}" Tag="animation_all" Click="select_all" />
                        <Button Style="{StaticResource selectNoneBtn}" Tag="animation_all" Click="select_none" />
                    </StackPanel>
                </GroupBox.Header>
                <StackPanel Orientation="Vertical" Margin="5">
                    <CheckBox Content="Remove slide transitions" ToolTip="Delete all transitions between slides." IsChecked="{Binding cl_remove_transitions, Mode=TwoWay}" Margin="5,2" />
                    <CheckBox Content="Remove shape animations" ToolTip="Delete all shape animations in the entire slide deck." IsChecked="{Binding cl_remove_animations, Mode=TwoWay}" Margin="5,2" />
                </StackPanel>
            </GroupBox>

            <GroupBox Grid.Row="0" Grid.Column="1" Margin="5">
                <GroupBox.Header>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Clean up format" />
                        <Button Style="{StaticResource selectAllBtn}" Tag="format_all" Click="select_all" />
                        <Button Style="{StaticResource selectNoneBtn}" Tag="format_all" Click="select_none" />
                    </StackPanel>
                </GroupBox.Header>
                <StackPanel Orientation="Vertical" Margin="5">
                    <CheckBox Content="Disable automatic black/white mode" ToolTip="Replace the black/white mode 'Automatic' with 'Grayscale'." IsChecked="{Binding cl_blackwhite_gray_scale, Mode=TwoWay}" Margin="5,2" />
                    <CheckBox Content="Remove double spaces" ToolTip="Delete all double spaces in the entire slide deck." IsChecked="{Binding cl_remove_doublespaces, Mode=TwoWay}" Margin="5,2" />
                    <CheckBox Content="Remove empty placeholders" ToolTip="Delete empty placeholder text boxes in the entire slide deck." IsChecked="{Binding cl_remove_empty_placeholders, Mode=TwoWay}" Margin="5,2" />
                </StackPanel>
            </GroupBox>

            <GroupBox Grid.Row="1" Grid.Column="1" Margin="5">
                <GroupBox.Header>
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Slide master" />
                        <Button Style="{StaticResource selectAllBtn}" Tag="master_all" Click="select_all" />
                        <Button Style="{StaticResource selectNoneBtn}" Tag="master_all" Click="select_none" />
                    </StackPanel>
                </GroupBox.Header>
                <StackPanel Orientation="Vertical" Margin="5">
                    <CheckBox Content="Remove unused slide layouts" ToolTip="Delete all unused slide-master layouts as well as empty slide masters (designs)." IsChecked="{Binding cl_remove_unused_masters, Mode=TwoWay}" Margin="5,2" />
                    <CheckBox Content="Remove unused slide masters" ToolTip="Delete all unused slide masters (designs)." IsChecked="{Binding cl_remove_unused_designs, Mode=TwoWay}" Margin="5,2" />
                </StackPanel>
            </GroupBox>
        </Grid>
        
        <Grid Margin="0">
          <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel Orientation="Horizontal" Grid.Column="1">
              <Button Margin="5" MinWidth="80" Padding="5,4" Content="Clean up" IsDefault="True" Click="cleanup"/>
              <Button Margin="5" MinWidth="80" Padding="5,4" Content="Cancel" IsCancel="True"  Click="cancel"/>
          </StackPanel>
      </Grid>
    </StackPanel>
</Window>