<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    ResizeMode="NoResize" SizeToContent="WidthAndHeight" WindowStartupLocation="CenterScreen"
    Title="Select shapes"
    ShowInTaskbar="False" MinWidth="400">

    <Window.Resources>
        <Style x:Key="selectAllBtn" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Static ToolBar.ButtonStyleKey}}">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="Content" Value="&#xE73A;" />
        </Style>
        <Style x:Key="selectNoneBtn" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Static ToolBar.ButtonStyleKey}}">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="Content" Value="&#xE739;" />
        </Style>
   </Window.Resources>

    <StackPanel x:Name="DataPanel" Orientation="Vertical" Margin="5">
        
        <Grid Margin="5" HorizontalAlignment="Center">
          <Grid.RowDefinitions>
              <RowDefinition />
              <RowDefinition />
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
              <ColumnDefinition Width="200" />
              <ColumnDefinition Width="200" />
              <ColumnDefinition Width="200" />
          </Grid.ColumnDefinitions>

        <!-- <Label Content="Select properties for selection:"/> -->

        <GroupBox Grid.Row="0" Grid.Column="0" Margin="5">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal">
                    <!-- <CheckBox Content="Shape type and size" IsChecked="{Binding shape_all, Mode=TwoWay}" FontWeight="Bold" /> -->
                    <Label Content="Shape type and size" />
                    <Button Style="{StaticResource selectAllBtn}" Tag="shape_all" Click="select_all" />
                    <Button Style="{StaticResource selectNoneBtn}" Tag="shape_all" Click="select_none" />
                </StackPanel>
            </GroupBox.Header>
            <StackPanel Orientation="Vertical" Margin="5">
                <CheckBox Content="Type/shape" IsChecked="{Binding sk_shape_type, Mode=TwoWay}" Margin="5,1" />
                <CheckBox Content="Width" IsChecked="{Binding sk_shape_width, Mode=TwoWay}" Margin="5,1" />
                <CheckBox Content="Height" IsChecked="{Binding sk_shape_height, Mode=TwoWay}" Margin="5,1" />
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="0" Grid.Column="1" Margin="5">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal">
                    <!-- <CheckBox Content="Shape position" IsChecked="{Binding pos_all, Mode=TwoWay}" FontWeight="Bold" /> -->
                    <Label Content="Shape position" />
                    <Button Style="{StaticResource selectAllBtn}" Tag="pos_all" Click="select_all" />
                    <Button Style="{StaticResource selectNoneBtn}" Tag="pos_all" Click="select_none" />
                </StackPanel>
            </GroupBox.Header>
            <StackPanel Orientation="Vertical" Margin="5">
                <CheckBox Content="Left" IsChecked="{Binding sk_pos_left, Mode=TwoWay}" Margin="5,1"/>
                <CheckBox Content="Top" IsChecked="{Binding sk_pos_top, Mode=TwoWay}" Margin="5,1" />

                <CheckBox Content="Right" IsChecked="{Binding sk_pos_right, Mode=TwoWay}" Margin="5,1" />
                <CheckBox Content="Bottom" IsChecked="{Binding sk_pos_bottom, Mode=TwoWay}" Margin="5,1" />

                <CheckBox Content="Rotation" IsChecked="{Binding sk_pos_rotation, Mode=TwoWay}" Margin="5,1" />
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="1" Grid.Column="0" Margin="5">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal">
                    <!-- <CheckBox Content="Background/fill" IsChecked="{Binding fill_all, Mode=TwoWay}" FontWeight="Bold" /> -->
                    <Label Content="Background/fill" />
                    <Button Style="{StaticResource selectAllBtn}" Tag="fill_all" Click="select_all" />
                    <Button Style="{StaticResource selectNoneBtn}" Tag="fill_all" Click="select_none" />
                </StackPanel>
            </GroupBox.Header>
            <StackPanel Orientation="Vertical" Margin="5">
                <CheckBox Content="Art" ToolTip="Solid/gradient/pattern" IsChecked="{Binding sk_fill_type, Mode=TwoWay}" Margin="5,1" />
                <CheckBox Content="Color" IsChecked="{Binding sk_fill_color, Mode=TwoWay}" Margin="5,1" />
                <CheckBox Content="Transparency" IsChecked="{Binding sk_fill_transp, Mode=TwoWay}" Margin="5,1" />
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="1" Grid.Column="1" Margin="5">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal">
                    <!-- <CheckBox Content="Line/border" IsChecked="{Binding line_all, Mode=TwoWay}" FontWeight="Bold" /> -->
                    <Label Content="Line/border" />
                    <Button Style="{StaticResource selectAllBtn}" Tag="line_all" Click="select_all" />
                    <Button Style="{StaticResource selectNoneBtn}" Tag="line_all" Click="select_none" />
                </StackPanel>
            </GroupBox.Header>
            <StackPanel Orientation="Vertical" Margin="5">
                <CheckBox Content="Outline weight" IsChecked="{Binding sk_line_weight, Mode=TwoWay}" Margin="5,1" />
                <CheckBox Content="Type/line style" IsChecked="{Binding sk_line_style, Mode=TwoWay}" Margin="5,1" />
                <CheckBox Content="Color" IsChecked="{Binding sk_line_color, Mode=TwoWay}" Margin="5,1" />
                <CheckBox Content="Start (arrow type)" IsChecked="{Binding sk_line_begin, Mode=TwoWay}" Margin="5,1" />
                <CheckBox Content="End (arrow type)" IsChecked="{Binding sk_line_end, Mode=TwoWay}" Margin="5,1" />
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="1" Grid.Column="2" Margin="5">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal">
                    <!-- <CheckBox Content="Font" IsChecked="{Binding font_all, Mode=TwoWay}" FontWeight="Bold" /> -->
                    <Label Content="Font" />
                    <Button Style="{StaticResource selectAllBtn}" Tag="font_all" Click="select_all" />
                    <Button Style="{StaticResource selectNoneBtn}" Tag="font_all" Click="select_none" />
                </StackPanel>
            </GroupBox.Header>
            <StackPanel Orientation="Vertical" Margin="5">
                <CheckBox Content="Font" IsChecked="{Binding sk_font_name, Mode=TwoWay}" Margin="5,1" />
                <CheckBox Content="Font size" IsChecked="{Binding sk_font_size, Mode=TwoWay}" Margin="5,1" />
                <CheckBox Content="Font color" IsChecked="{Binding sk_font_color, Mode=TwoWay}" Margin="5,1" />
                <CheckBox Content="Style" ToolTip="Bold/underline/italic" IsChecked="{Binding sk_font_style, Mode=TwoWay}" Margin="5,1" />
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="0" Grid.Column="2" Margin="5">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal">
                    <!-- <CheckBox Content="Content" IsChecked="{Binding content_all, Mode=TwoWay}" FontWeight="Bold" /> -->
                    <Label Content="Content" />
                    <Button Style="{StaticResource selectAllBtn}" Tag="content_all" Click="select_all" />
                    <Button Style="{StaticResource selectNoneBtn}" Tag="content_all" Click="select_none" />
                </StackPanel>
            </GroupBox.Header>
            <StackPanel Orientation="Vertical" Margin="5">
                <CheckBox Content="Number of characters" IsChecked="{Binding sk_content_len, Mode=TwoWay}" Margin="5,1" />
                <CheckBox Content="Text" IsChecked="{Binding sk_content_text, Mode=TwoWay}" Margin="5,1" />
            </StackPanel>
        </GroupBox>

        </Grid>

        <Grid Margin="0">
          <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel Orientation="Horizontal" Grid.Column="1">
              <Button Margin="5" MinWidth="80" Padding="5,4" Content="Preview"                   Click="shapes_select"/>
              <Button Margin="5" MinWidth="80" Padding="5,4" Content="Select" IsDefault="True" Click="shapes_select_close"/>
              <Button Margin="5" MinWidth="80" Padding="5,4" Content="Cancel" IsCancel="True"  Click="cancel"/>
          </StackPanel>
      </Grid>
    </StackPanel>
</Window>